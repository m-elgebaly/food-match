# ─────────────────────────────────────────────────────────────────
# Supabase — get these from your project's Settings > API page
# https://app.supabase.com/project/<your-project>/settings/api
# ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─────────────────────────────────────────────────────────────────
# App URL — used for generating shareable group links
# In production: https://your-app.vercel.app
# In dev:        http://localhost:3000
# ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
